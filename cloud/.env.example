# Plugin-facing runtime
CLOUDFLARE_WORKER_URL=
PLUGIN_SHARED_SECRET=

# Session / storage
SESSION_STORE_KIND=memory
TRACE_STORE_KIND=memory

# Notes
# - Use `wrangler login` for Cloudflare auth instead of storing account/token here.
# - Put provider secrets like `OPENAI_API_KEY` in Cloudflare Worker secrets or local `.dev.vars`.
