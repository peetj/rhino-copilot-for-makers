{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "types": ["@cloudflare/workers-types"],
    "skipLibCheck": true
  },
  "include": [
    "worker/src/**/*.ts",
    "agents/**/*.ts",
    "shared/**/*.ts",
    "../Contracts/**/*.ts"
  ]
}

